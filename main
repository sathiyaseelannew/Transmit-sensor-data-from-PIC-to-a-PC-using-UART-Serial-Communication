#include <xc.h>
#include <stdio.h>

#define _XTAL_FREQ 20000000

// CONFIGURATION BITS
#pragma config FOSC = HS
#pragma config WDTE = OFF
#pragma config PWRTE = ON
#pragma config BOREN = ON
#pragma config LVP = OFF
#pragma config CPD = OFF
#pragma config WRT = OFF
#pragma config CP = OFF


// UART INITIALIZATION
void UART_Init()
{
    TRISC6 = 0;   // TX pin output
    TRISC7 = 1;   // RX pin input

    SPBRG = 129;  // 9600 baud @20MHz
    BRGH = 1;

    SYNC = 0;     // Asynchronous
    SPEN = 1;     // Enable serial port

    TXEN = 1;     // Enable transmit
    CREN = 1;     // Enable receive
}

// SEND ONE CHARACTER
void UART_Write(char data)
{
    while(!TXIF); 
    TXREG = data;
}

// SEND STRING
void UART_Write_Text(const char *text)
{
    while(*text)
    {
        UART_Write(*text++);
    }
}


// ADC INITIALIZATION
void ADC_Init()
{
    ADCON0 = 0x41;   // AN0 channel, ADC ON
    ADCON1 = 0x80;   // Right justified result
}

// READ ADC VALUE
unsigned int ADC_Read()
{
    GO_DONE = 1;     // Start conversion
    while(GO_DONE);  // Wait until conversion finished

    return ((ADRESH<<8) + ADRESL);
}


void main()
{
    unsigned int adc_value;
    char buffer[30];

    UART_Init();
    ADC_Init();

    while(1)
    {
        adc_value = ADC_Read();

        // integer to string
        sprintf(buffer,"TEMP: %u C\r\n", adc_value);

        // Send via UART
        UART_Write_Text(buffer);

        __delay_ms(100);
    }
}
